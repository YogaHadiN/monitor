APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Push trigger ke atika (notifikasi PWA iPhone saat ada chat_admin baru)
# URL endpoint atika dan shared HMAC secret (SAMA dengan PUSH_TRIGGER_SECRET di atika).
PUSH_TRIGGER_URL=https://www.kezia.id/api/push/trigger
PUSH_TRIGGER_SECRET=

# Webhook mutasi bank (AWS SES inbound via Lambda)
# Shared secret untuk HMAC-SHA256 signature header X-Signature.
MUTASI_WEBHOOK_SECRET=
# Domain pengirim yang diizinkan, comma-separated.
MUTASI_ALLOWED_SENDER_DOMAINS=kopra.mandiri.co.id
# Disk Storage yang menyimpan raw email dari Lambda.
MUTASI_S3_DISK=s3_mutasi
# Bucket S3 tempat Lambda landing raw email Kopra (terpisah dari AWS_BUCKET).
AWS_MUTASI_BUCKET=
# Override AWS credentials kalau bucket mutasi pakai IAM principal beda
# dari AWS_* utama (kosongkan untuk ikut credentials utama):
# AWS_MUTASI_ACCESS_KEY_ID=
# AWS_MUTASI_SECRET_ACCESS_KEY=
# AWS_MUTASI_REGION=
# Queue (redis) untuk job parsing mutasi.
MUTASI_QUEUE_CONNECTION=redis
MUTASI_QUEUE_NAME=mutasi

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
